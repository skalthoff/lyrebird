        "pt-BR": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Não foi possível alcançar %@. Tentando novamente…"
          }
        },
        "it": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Impossibile raggiungere %@. Nuovo tentativo…"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Не удаётся достичь %@. Повторная попытка…"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "needs_review",
