            "value": "⌘Fを押すと、すぐに検索に移動し、ライブラリ内の曲、アルバム、アーティストを検索できます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Pressione ⌘F para ir direto à busca e encontrar qualquer música, álbum ou artista na sua biblioteca."
          }
        }
      }
    },
