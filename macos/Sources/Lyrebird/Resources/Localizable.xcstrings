    "tour.mini_player.body": {
      "comment": "Feature-tour card body: detachable mini player.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press ⌘⌥P for a compact, always-on-top player you can tuck into a corner while you work."
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
