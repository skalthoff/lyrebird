{
  "sourceLanguage": "en",
  "strings": {
    "about.window.title": {
      "comment": "Window title for the dedicated About Lyrebird window (#25).",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "About Lyrebird"
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Acerca de Lyrebird"
          }
        }
      }
    },
    "app.name": {
      "comment": "Brand name shown in the sidebar header and splash screens.",
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Lyrebird"
          }
        },
        "es": {
          "stringUnit": {
            "state": "needs_review",
            "value": "Lyrebird"
          }
        }
      }
    },
    "app.subtitle.desktop": {
