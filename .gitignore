# Rust
target/
**/*.rs.bk

# Swift Package Manager. macos/Package.resolved is tracked on purpose: it
# pins Sparkle/Nuke/Sentry for tagged releases and feeds the CI cache keys
# (hashFiles rotates them on dependency bumps). Update via
# `swift package update --package-path macos` and commit the diff.
.build/
.swiftpm/

# Generated (produced by Scripts/build-core.sh)
macos/Lyrebird.xcframework/
macos/Sources/LyrebirdCore/Generated/
macos/build/

# Generated Windows artifacts (produced by windows/tools/*.ps1)
windows/Lyrebird.Core/Generated/*.cs
windows/Lyrebird.Core/native/win-x64/lyrebird_core.*
windows/Lyrebird.Core/native/win-arm64/lyrebird_core.*

# Visual Studio / .NET build output
windows/**/bin/
windows/**/obj/
windows/**/*.user
windows/.vs/

# Flatpak packaging (downloaded generator cache)
linux/flatpak/.cache/

# Symbol files / debug
*.pdb
*.dSYM/

# design-sync → Claude Design. Staged converter, generated bundle, machine
# state, and the DS package's deps/build are scratch. The durable sync inputs
# (design/lyrebird-ds/src, .design-sync/config.json + NOTES.md + previews/) ARE tracked.
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
design/lyrebird-ds/node_modules/
design/lyrebird-ds/dist/

# Editor + OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Claude Code workspace artifacts (batch plans, worktree metadata, etc.)
# We DO track .claude/agents/, .claude/commands/, and .claude/workflows/ —
# they are how the agentic pipeline ships to the team. Everything else under
# .claude/ is local scratch. Pattern note: we use `.claude/*` (not `.claude/`)
# so git can re-include subdirectories via `!` exceptions below.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/workflows/
